# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Huis ter Huynen вЂ“ Environment Variables
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Kopieer dit bestand naar .env.local
# en vul de waarden in.

# в”Ђв”Ђ Supabase (verplicht voor database) в”Ђв”Ђ
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# в”Ђв”Ђ Admin beveiliging (verplicht voor /admin) в”Ђв”Ђ
ADMIN_SECRET=

# в”Ђв”Ђ Gast sessie (verplicht voor /app afscherming) в”Ђв”Ђ
# Min 32 willekeurige tekens. Wordt gebruikt om de HttpOnly stay-cookie
# te signen die /app en /concierge afschermt voor niet-gasten.
# Zet alleen in Vercel env vars (Production + Preview), niet committen.
# Roteren = alle lopende gasten moeten opnieuw via hun welkomstmail-link.
STAY_COOKIE_SECRET=

# в”Ђв”Ђ E-mail (verplicht voor boekingsbevestigingen) в”Ђв”Ђ
RESEND_API_KEY=

# в”Ђв”Ђ AI Chatbot (OpenAI) в”Ђв”Ђ
# Zonder key werkt de chatbot met fallback-antwoorden
OPENAI_API_KEY=

# в”Ђв”Ђ Nuki Smart Lock в”Ђв”Ђ
# Zonder keys werkt de deur in demo-modus
NUKI_API_KEY=
NUKI_SMARTLOCK_ID=

# в”Ђв”Ђ Mollie Betalingen в”Ђв”Ђ
# Zonder key wordt een simpel formulier getoond
MOLLIE_API_KEY=

# в”Ђв”Ђ Google Maps / Business Reviews в”Ђв”Ђ
# Vereist voor het ophalen van Google Business reviews
# Place ID vind je op: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=ChIJEZ3h8BUxyEcRqPvq9qnzXyk

# в”Ђв”Ђ Weer (OpenWeatherMap) в”Ђв”Ђ
# Zonder key wordt een seizoensschatting getoond
OPENWEATHER_API_KEY=

# в”Ђв”Ђ e-Boekhouden integratie в”Ђв”Ђ
# Optioneel вЂ” voor automatisch doorboeken van facturen
EBOEKHOUDEN_API_TOKEN=

# в”Ђв”Ђ App URL (gast-app, inclusief pad /concierge) в”Ђв”Ђ
NEXT_PUBLIC_APP_URL=https://huisterhuynen.nl/concierge

# в”Ђв”Ђ Vercel Cron beveiliging в”Ђв”Ђ
# Vercel vult CRON_SECRET automatisch in op het platform.
# Lokaal testen: stel zelf een willekeurige string in.
CRON_SECRET=

# в”Ђв”Ђ Meta Pixel + Conversions API в”Ђв”Ђ
# Zonder Pixel ID + token wordt er niets naar Meta gestuurd (silent no-op).
# Pixel ID: Events Manager в†’ Settings в†’ Pixel ID
# Access token: Events Manager в†’ Settings в†’ Generate access token
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Tijdens setup invullen met Test Events code uit Events Manager в†’ Test Events.
# Daarna LEEG laten вЂ” anders zien jouw productie-events er als test-events uit.
META_CAPI_TEST_EVENT_CODE=

# в”Ђв”Ђ Google Analytics 4 (direct, optioneel) в”Ђв”Ђ
# Met dit ID vuurt de app GA4-events rechtstreeks (zelfde patroon als de Meta
# Pixel), consent-gated op de 'statistics'-categorie. Zonder ID: silent no-op.
# LET OP: gebruik OFWEL dit ID OFWEL een GA4-config-tag in GTM вЂ” niet beide,
# anders worden page_views dubbel geteld. Mapping: Leadв†’generate_lead,
# InitiateCheckoutв†’begin_checkout, Subscribeв†’newsletter_subscribe,
# BookingComRedirectв†’outbound_ota, PageViewв†’page_view, Purchaseв†’purchase.
NEXT_PUBLIC_GA4_ID=

# в”Ђв”Ђ Google Tag Manager в”Ђв”Ђ
# Web container. Zonder ID wordt er geen GTM script geladen.
NEXT_PUBLIC_GTM_ID=
# Optioneel: 1st-party server-side GTM URL (Cloud Run / Stape) op eigen subdomein.
# Bijv. https://sgtm.huisterhuynen.nl вЂ” laadt gtm.js + ns.html via 1st party.
NEXT_PUBLIC_SGTM_URL=

# в”Ђв”Ђ Cookie consent в”Ђв”Ђ
# Verhoog dit nummer om alle bezoekers opnieuw toestemming te laten geven.
# Doe dit zodra je een nieuwe categorie of vendor toevoegt.
NEXT_PUBLIC_CONSENT_VERSION=2026.05
