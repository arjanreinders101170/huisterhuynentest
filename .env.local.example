# ═══════════════════════════════════════
# Huis ter Huynen – Environment Variables
# ═══════════════════════════════════════
# Kopieer dit bestand naar .env.local
# en vul de waarden in.

# ── AI Chatbot (OpenAI) ──
# Zonder key werkt de chatbot met fallback-antwoorden
OPENAI_API_KEY=

# ── Nuki Smart Lock ──
# Zonder keys werkt de deur in demo-modus.
NUKI_API_KEY=
# DEPRECATED: gebruik NUKI_SMARTLOCK_ID_LODGE_1 / _LODGE_2 hieronder.
# Wordt enkel nog gebruikt als fallback wanneer de lodge-specifieke ids ontbreken.
NUKI_SMARTLOCK_ID=
# Per-lodge smartlock ids (verplicht voor productie):
NUKI_SMARTLOCK_ID_LODGE_1=
NUKI_SMARTLOCK_ID_LODGE_2=

# ── Mollie Betalingen ──
# Zonder key wordt een simpel formulier getoond
MOLLIE_API_KEY=
# Optioneel: HMAC-secret voor webhook-signatuur (zet zodra Mollie dashboard
# webhook signing geconfigureerd heeft). Zonder secret blijft de webhook
# fallback op verify-by-API + idempotency.
MOLLIE_WEBHOOK_SECRET=

# ── Vercel KV (rate limiting) ──
# Zonder deze variabelen valt de rate-limiter terug op een in-memory map
# (per Vercel-instance — niet geschikt voor productie).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── App URL ──
NEXT_PUBLIC_APP_URL=https://app.huisterhuynen.nl
