# ═══════════════════════════════════════
# Huis ter Huynen – Environment Variables
# ═══════════════════════════════════════
# Kopieer dit bestand naar .env.local
# en vul de waarden in.

# ── Supabase (verplicht voor database) ──
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Admin beveiliging (verplicht voor /admin) ──
ADMIN_SECRET=

# ── Gast sessie (verplicht voor /app afscherming) ──
# Min 32 willekeurige tekens. Wordt gebruikt om de HttpOnly stay-cookie
# te signen die /app en /concierge afschermt voor niet-gasten.
# Zet alleen in Vercel env vars (Production + Preview), niet committen.
# Roteren = alle lopende gasten moeten opnieuw via hun welkomstmail-link.
STAY_COOKIE_SECRET=

# ── E-mail (verplicht voor boekingsbevestigingen) ──
RESEND_API_KEY=

# ── AI Chatbot (OpenAI) ──
# Zonder key werkt de chatbot met fallback-antwoorden
OPENAI_API_KEY=

# ── Eigenaar e-mail (notificaties bij boekingen, betalingen, aanvragen) ──
OWNER_EMAIL=

# ── WiFi (wordt getoond in gast-app en AI-chatbot) ──
# Gebruik NEXT_PUBLIC_ prefix zodat het beschikbaar is in client-componenten.
# Zet de waarde in Vercel env vars — niet in code committen.
NEXT_PUBLIC_WIFI_PASSWORD=

# ── Nuki Smart Lock ──
# Zonder keys werkt de deur in demo-modus
NUKI_API_KEY=
# Lodge-specifieke slot-IDs (vul in zodra de Nuki's geplaatst zijn)
NUKI_SMARTLOCK_ID_LODGE_1=   # De Heide
NUKI_SMARTLOCK_ID_LODGE_2=   # De Eik
# Legacy single-lodge fallback — kan worden leeggelaten als beide vars hierboven zijn ingevuld
NUKI_SMARTLOCK_ID=

# ── Mollie Betalingen ──
# Zonder key wordt een simpel formulier getoond
MOLLIE_API_KEY=

# ── Google Maps / Business Reviews ──
# Vereist voor het ophalen van Google Business reviews
# Place ID vind je op: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=ChIJEZ3h8BUxyEcRqPvq9qnzXyk

# ── Weer (OpenWeatherMap) ──
# Zonder key wordt een seizoensschatting getoond
OPENWEATHER_API_KEY=

# ── e-Boekhouden integratie ──
# Optioneel — voor automatisch doorboeken van facturen
EBOEKHOUDEN_API_TOKEN=

# ── App URL (gast-app, inclusief pad /concierge) ──
NEXT_PUBLIC_APP_URL=https://huisterhuynen.nl/concierge

# ── Vercel Cron beveiliging ──
# Vercel vult CRON_SECRET automatisch in op het platform.
# Lokaal testen: stel zelf een willekeurige string in.
CRON_SECRET=

# ── Meta Pixel + Conversions API ──
# Zonder Pixel ID + token wordt er niets naar Meta gestuurd (silent no-op).
# Pixel ID: Events Manager → Settings → Pixel ID
# Access token: Events Manager → Settings → Generate access token
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Tijdens setup invullen met Test Events code uit Events Manager → Test Events.
# Daarna LEEG laten — anders zien jouw productie-events er als test-events uit.
META_CAPI_TEST_EVENT_CODE=

# ── Google Analytics 4 (direct, optioneel) ──
# Met dit ID vuurt de app GA4-events rechtstreeks (zelfde patroon als de Meta
# Pixel), consent-gated op de 'statistics'-categorie. Zonder ID: silent no-op.
# LET OP: gebruik OFWEL dit ID OFWEL een GA4-config-tag in GTM — niet beide,
# anders worden page_views dubbel geteld. Mapping: Lead→generate_lead,
# InitiateCheckout→begin_checkout, Subscribe→newsletter_subscribe,
# BookingComRedirect→outbound_ota, PageView→page_view, Purchase→purchase.
NEXT_PUBLIC_GA4_ID=

# ── Google Tag Manager ──
# Web container. Zonder ID wordt er geen GTM script geladen.
NEXT_PUBLIC_GTM_ID=
# Optioneel: 1st-party server-side GTM URL (Cloud Run / Stape) op eigen subdomein.
# Bijv. https://sgtm.huisterhuynen.nl — laadt gtm.js + ns.html via 1st party.
NEXT_PUBLIC_SGTM_URL=

# ── Cookie consent ──
# Verhoog dit nummer om alle bezoekers opnieuw toestemming te laten geven.
# Doe dit zodra je een nieuwe categorie of vendor toevoegt.
NEXT_PUBLIC_CONSENT_VERSION=2026.05
